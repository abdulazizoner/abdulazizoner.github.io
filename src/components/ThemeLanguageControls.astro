---
const base = import.meta.env.BASE_URL;
---

<div class="lang-switch" role="group" data-aria-en="Language" data-aria-tr="Dil" aria-label="Language">
  <button type="button" class="lang-btn active" data-lang-btn="en" aria-pressed="true">EN</button>
  <button type="button" class="lang-btn" data-lang-btn="tr" aria-pressed="false">TR</button>
</div>
<button
  type="button"
  id="theme-btn"
  class="theme-btn"
  data-aria-en="Toggle color theme"
  data-aria-tr="Renk temasını değiştir"
  aria-label="Toggle color theme"
>
  <svg id="icon-sun" class="hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"
    ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"
    ></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line
      x1="1"
      y1="12"
      x2="3"
      y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
      x1="18.36"
      y1="5.64"
      x2="19.78"
      y2="4.22"></line></svg
  >
  <svg id="icon-moon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"
    ><path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path></svg
  >
  <span class="toggle-track" id="theme-track"><span class="toggle-thumb"></span></span>
</button>
